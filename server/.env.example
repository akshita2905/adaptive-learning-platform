MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=learning_path_app
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_EXP_HOURS=72
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI + media (read via os.getenv in config.get_settings — optional; fallbacks if empty)
# Create server/.env from this file; never commit real keys.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
YOUTUBE_API_KEY=your-youtube-api-key-here

# Cache TTL for identical /generate-path requests (seconds)
GENERATE_CACHE_TTL_SECONDS=300
YOUTUBE_MAX_PER_TOPIC=3
